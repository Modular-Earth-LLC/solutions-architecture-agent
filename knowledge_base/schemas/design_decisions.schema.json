{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/paulpham157/multi-agent-ai-development-framework/schemas/design_decisions.schema.json",
  "title": "Design Decisions",
  "description": "Schema for architecture decisions, tech stack, costs, estimates, and project plans",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "executive_summary": {
      "type": "object",
      "properties": {
        "recommendation": {"type": "string"},
        "business_value": {"type": "array", "items": {"type": "string"}},
        "investment_required": {"type": "object"},
        "key_risks": {"type": "array", "items": {"type": "object"}},
        "go_no_go_recommendation": {"type": "string"}
      }
    },
    "tech_stack": {
      "type": "object",
      "properties": {
        "llm_providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider": {"type": "string"},
              "models": {"type": "array", "items": {"type": "string"}},
              "rationale": {"type": "string"},
              "cost_estimate": {"type": "string"}
            }
          }
        },
        "orchestration_framework": {"type": "string"},
        "backend_technologies": {"type": "array", "items": {"type": "string"}},
        "frontend_technologies": {"type": "array", "items": {"type": "string"}},
        "infrastructure": {"type": "array", "items": {"type": "string"}},
        "integration_approach": {
          "type": "object",
          "description": "Integration strategy with external systems",
          "properties": {
            "external_systems": {"type": "array", "items": {"type": "string"}},
            "authentication_strategy": {"type": "string"},
            "api_versioning": {"type": "string"},
            "error_handling_strategy": {"type": "string"},
            "rate_limiting": {"type": "string"}
          }
        },
        "alternatives_considered": {"type": "array", "items": {"type": "object"}}
      }
    },
    "architecture_design": {
      "type": "object",
      "properties": {
        "diagram_format": {"type": "string", "enum": ["mermaid", "ascii", "lucidchart", "draw.io", "google_draw"]},
        "diagram_content": {"type": "string"},
        "components": {"type": "array", "items": {"type": "object"}},
        "data_flows": {"type": "array", "items": {"type": "object"}},
        "security_boundaries": {
          "type": "object",
          "description": "Security zones and boundaries",
          "properties": {
            "public_facing": {"type": "array", "items": {"type": "string"}},
            "internal_only": {"type": "array", "items": {"type": "string"}},
            "data_encryption": {"type": "array", "items": {"type": "string"}},
            "compliance_zones": {"type": "array", "items": {"type": "string"}}
          }
        },
        "integration_points": {"type": "array", "items": {"type": "string"}}
      }
    },
    "team_composition": {
      "type": "object",
      "properties": {
        "decision_date": {"type": "string", "format": "date"},
        "last_updated": {"type": "string", "format": "date"},
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {"type": "string"},
              "skills_required": {"type": "array", "items": {"type": "string"}},
              "team_size": {"type": "integer", "minimum": 0},
              "allocation_percent": {"type": "number", "minimum": 0, "maximum": 100},
              "cost_per_role": {"type": "string"},
              "experience_level": {
                "type": "string",
                "enum": ["junior", "mid_level", "senior", "expert"]
              }
            }
          }
        },
        "total_team_size": {"type": "integer", "minimum": 0},
        "total_ftes": {"type": "number", "minimum": 0},
        "hiring_needs": {
          "type": "object",
          "description": "Hiring requirements for the project",
          "properties": {
            "new_hires_required": {"type": "array", "items": {"type": "string"}},
            "contractors_needed": {"type": "array", "items": {"type": "string"}},
            "hiring_timeline": {"type": "string"},
            "recruitment_cost": {"type": "number", "minimum": 0}
          }
        },
        "training_needed": {"type": "array", "items": {"type": "string"}},
        "timeline": {"type": "string"}
      }
    },
    "estimates": {
      "type": "object",
      "properties": {
        "total_engineering_hours": {"type": "number", "minimum": 0},
        "timeline_weeks": {"type": "number", "minimum": 0},
        "complexity_rating": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "VERY_HIGH"]
        },
        "confidence_level": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"]
        },
        "assumptions": {"type": "array", "items": {"type": "string"}},
        "risk_buffers": {"type": "object"}
      }
    },
    "costs": {
      "type": "object",
      "properties": {
        "development_costs": {
          "type": "object",
          "properties": {
            "total": {"type": "number", "minimum": 0},
            "by_role": {"type": "object"}
          }
        },
        "infrastructure_costs": {
          "type": "object",
          "properties": {
            "monthly": {"type": "number", "minimum": 0},
            "annual": {"type": "number", "minimum": 0},
            "breakdown": {"type": "object"}
          }
        },
        "third_party_costs": {"type": "object"},
        "total_cost_of_ownership": {
          "type": "object",
          "properties": {
            "year_1": {"type": "number"},
            "year_2": {"type": "number"},
            "year_3": {"type": "number"}
          }
        },
        "roi_projections": {"type": "object"}
      }
    },
    "project_plan": {
      "type": "object",
      "properties": {
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "duration": {"type": "string"},
              "deliverables": {"type": "array", "items": {"type": "string"}},
              "dependencies": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "milestones": {"type": "array", "items": {"type": "object"}},
        "critical_path": {"type": "array", "items": {"type": "string"}},
        "success_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "model_evaluation": {
      "type": "object",
      "properties": {
        "models_evaluated": {"type": "array", "items": {"type": "object"}},
        "evaluation_criteria": {"type": "array", "items": {"type": "object"}},
        "evaluation_methodology": {"type": "string"},
        "benchmark_results": {"type": "object", "description": "Benchmark test results organized by model"},
        "recommended_model": {"type": "string"},
        "model_selection_rationale": {"type": "string"},
        "fallback_model": {"type": "string"},
        "selected_models": {"type": "array", "items": {"type": "object"}}
      }
    },
    "risks_and_mitigation": {
      "type": "object",
      "description": "Categorized risks with technical, business, and dependencies separation",
      "properties": {
        "decision_date": {"type": "string", "format": "date"},
        "last_updated": {"type": "string", "format": "date"},
        "technical_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "risk_id": {"type": "string"},
              "risk": {"type": "string"},
              "impact": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "probability": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "mitigation_strategy": {"type": "string"},
              "contingency_plan": {"type": "string"},
              "owner": {"type": "string"}
            }
          }
        },
        "business_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "risk_id": {"type": "string"},
              "risk": {"type": "string"},
              "impact": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "probability": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "mitigation_strategy": {"type": "string"},
              "contingency_plan": {"type": "string"},
              "owner": {"type": "string"}
            }
          }
        },
        "dependencies_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dependency": {"type": "string"},
              "risk": {"type": "string"},
              "mitigation": {"type": "string"}
            }
          }
        },
        "overall_risk_rating": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "risk_management_approach": {"type": "string"}
      }
    },
    "well_architected_assessment": {
      "type": "object",
      "description": "Compliance scores for 6 AWS Well-Architected pillars",
      "properties": {
        "operational_excellence": {"type": "number", "minimum": 0, "maximum": 10},
        "security": {"type": "number", "minimum": 0, "maximum": 10},
        "reliability": {"type": "number", "minimum": 0, "maximum": 10},
        "performance_efficiency": {"type": "number", "minimum": 0, "maximum": 10},
        "cost_optimization": {"type": "number", "minimum": 0, "maximum": 10},
        "sustainability": {"type": "number", "minimum": 0, "maximum": 10},
        "overall_score": {"type": "number", "minimum": 0, "maximum": 10}
      }
    },
    "_metadata": {
      "type": "object",
      "properties": {
        "created_date": {"type": "string", "format": "date"},
        "last_updated": {"type": "string", "format": "date"},
        "created_by_agent": {"type": "string"},
        "version": {"type": "string"}
      }
    }
  }
}
