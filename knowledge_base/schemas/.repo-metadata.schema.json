{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": ".repo-metadata.schema.json",
  "title": "Repository Metadata",
  "description": "Centralized metadata for the Solutions Architecture Agent repository. Single source of truth for version and counts.",
  "type": "object",
  "required": ["version", "architecture"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$",
      "description": "Repository version following semantic versioning"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date in YYYY-MM-DD format"
    },
    "status": {
      "type": "string",
      "description": "Current release status"
    },
    "repository": {
      "type": "string",
      "description": "GitHub repository URL"
    },
    "_comment": {
      "type": "string",
      "description": "Explanatory comment"
    },
    "architecture": {
      "type": "object",
      "description": "Plugin architecture metadata",
      "properties": {
        "type": { "type": "string", "description": "Architecture type (single-agent-with-skills)" },
        "skills": { "type": "integer", "minimum": 0, "description": "Number of SA lifecycle skills" },
        "sub_agents": { "type": "integer", "minimum": 0, "description": "Number of sub-agents" },
        "skill_names": { "type": "array", "items": { "type": "string" } },
        "sub_agent_names": { "type": "array", "items": { "type": "string" } }
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "knowledge_base": {
      "type": "object",
      "description": "Knowledge base metadata",
      "properties": {
        "files": { "type": "integer", "minimum": 0 },
        "schemas": { "type": "integer", "minimum": 0 },
        "format": { "type": "string" }
      }
    },
    "documentation": {
      "type": "object",
      "description": "Documentation file references",
      "properties": {
        "main_readme": { "type": "string" },
        "architecture": { "type": "string" },
        "contributing": { "type": "string" },
        "guides_directory": { "type": "string" }
      }
    },
    "tech_stack": {
      "type": "object",
      "description": "Technology stack metadata",
      "properties": {
        "primary_platform": { "type": "string" },
        "primary_language": { "type": "string" },
        "llm_providers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "maintenance": {
      "type": "object",
      "description": "Maintenance and CI/CD metadata",
      "properties": {
        "versioning_approach": { "type": "string" },
        "validation_scripts": { "type": "array", "items": { "type": "string" } },
        "update_frequency": { "type": "string" }
      }
    }
  }
}
