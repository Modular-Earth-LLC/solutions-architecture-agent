{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "system_config.schema.json",
  "title": "System Configuration",
  "description": "Platform settings, constraints, stakeholders, and team information. READ-ONLY at runtime — human-managed.",
  "type": "object",
  "required": ["project", "platform", "stakeholders", "constraints"],
  "additionalProperties": false,
  "patternProperties": {
    "^_": {}
  },
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$",
      "description": "Semantic version with optional prerelease tag (e.g., 0.1.0 or 0.1.0-alpha)"
    },
    "status": {
      "type": "string",
      "description": "Current release status"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date in YYYY-MM-DD format"
    },
    "project": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["web_app", "mobile_app", "api", "desktop_app", "data_pipeline", "ml_model", "genai_assistant", "automation_system"]
        },
        "organization": {"type": "string"},
        "description": {"type": "string"}
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "platform": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": {
          "type": "string",
          "enum": ["cursor", "claude_projects", "aws_bedrock", "azure_openai", "google_vertex", "custom"]
        },
        "deployment": {
          "type": "string",
          "enum": ["cloud", "on_prem", "hybrid", "edge"]
        },
        "region": {"type": "string"},
        "multi_cloud": {"type": "boolean"}
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "stakeholders": {
      "type": "object",
      "properties": {
        "decision_makers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role"],
            "properties": {
              "role": {"type": "string"},
              "name": {"type": "string"},
              "approval_authority": {"type": "string"},
              "communication_preference": {"type": "string"}
            },
            "patternProperties": { "^_comment": { "type": "string" } }
          }
        },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role"],
            "properties": {
              "role": {"type": "string"},
              "name": {"type": "string"},
              "expertise": {"type": "string"},
              "involvement_level": {
                "type": "string",
                "enum": ["primary", "secondary", "consultant", "reviewer"]
              }
            },
            "patternProperties": { "^_comment": { "type": "string" } }
          }
        },
        "end_users": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "persona": {"type": "string"},
              "count": {"type": "integer", "minimum": 0},
              "technical_level": {
                "type": "string",
                "enum": ["novice", "intermediate", "expert"]
              },
              "primary_needs": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "patternProperties": { "^_comment": { "type": "string" } }
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["budget", "timeline", "technical"],
      "properties": {
        "budget": {
          "type": "object",
          "properties": {
            "range": {"type": "string"},
            "currency": {"type": "string", "default": "USD"},
            "breakdown": {
              "type": "object",
              "properties": {
                "development": {"type": "number", "minimum": 0},
                "infrastructure": {"type": "number", "minimum": 0},
                "third_party_services": {"type": "number", "minimum": 0},
                "contingency_percent": {"type": "number", "minimum": 0, "maximum": 100, "default": 15}
              }
            },
            "approval_process": {"type": "string"}
          },
          "patternProperties": { "^_comment": { "type": "string" } }
        },
        "timeline": {
          "type": "object",
          "properties": {
            "deadline": {"type": "string", "format": "date"},
            "flexibility": {
              "type": "string",
              "enum": ["hard", "moderate", "soft"]
            },
            "milestones": {
              "type": "array",
              "items": {"type": "string"}
            },
            "business_drivers": {"type": "string"}
          },
          "patternProperties": { "^_comment": { "type": "string" } }
        },
        "compliance": {
          "type": "object",
          "properties": {
            "regulations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "certifications_required": {
              "type": "array",
              "items": {"type": "string"}
            },
            "data_residency": {"type": "string"},
            "audit_requirements": {"type": "string"}
          },
          "patternProperties": { "^_comment": { "type": "string" } }
        },
        "technical": {
          "type": "object",
          "properties": {
            "existing_infrastructure": {
              "type": "array",
              "items": {"type": "string"}
            },
            "required_integrations": {
              "type": "array",
              "items": {"type": "string"}
            },
            "technology_restrictions": {
              "type": "array",
              "items": {"type": "string"}
            },
            "performance_requirements": {
              "type": "object",
              "properties": {
                "latency_target_ms": {"type": "integer", "minimum": 0},
                "throughput_rps": {"type": "integer", "minimum": 0},
                "availability_percent": {"type": "number", "minimum": 0, "maximum": 100},
                "concurrent_users": {"type": "integer", "minimum": 0}
              }
            }
          },
          "patternProperties": { "^_comment": { "type": "string" } }
        },
        "strategic_priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        }
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "team": {
      "type": "object",
      "properties": {
        "current_size": {"type": "integer", "minimum": 0},
        "available_capacity_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "experience_level": {
          "type": "string",
          "enum": ["junior", "mid-level", "senior", "expert"]
        },
        "skills": {
          "type": "array",
          "items": {"type": "string"}
        },
        "gaps": {
          "type": "array",
          "items": {"type": "string"}
        },
        "hiring_budget": {"type": "string"},
        "training_budget": {"type": "string"}
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "preferences": {
      "type": "object",
      "properties": {
        "development_methodology": {
          "type": "string",
          "enum": ["agile", "scrum", "kanban", "waterfall", "hybrid"]
        },
        "code_quality_standards": {"type": "string"},
        "documentation_requirements": {"type": "string"},
        "testing_requirements": {"type": "string"},
        "ci_cd_preferences": {"type": "string"}
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "risk_tolerance": {
      "type": "object",
      "properties": {
        "innovation_vs_stability": {
          "type": "string",
          "enum": ["innovative", "balanced", "conservative"]
        },
        "cost_vs_speed": {
          "type": "string",
          "enum": ["optimize_cost", "balanced", "optimize_speed"]
        },
        "build_vs_buy": {
          "type": "string",
          "enum": ["prefer_build", "balanced", "prefer_buy"]
        }
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "output_configuration": {
      "type": "object",
      "properties": {
        "base_directory": {"type": "string", "default": "outputs"},
        "use_project_subdirectories": {"type": "boolean", "default": true},
        "timestamp_files": {"type": "boolean", "default": false}
      },
      "patternProperties": { "^_comment": { "type": "string" } }
    },
    "aws_well_architected_framework": {
      "type": "object",
      "description": "Authoritative AWS Well-Architected Framework definitions",
      "properties": {
        "_description": {"type": "string"},
        "pillars": {"type": "object"},
        "generative_ai_lens": {"type": "object"},
        "assessment_scoring": {"type": "object"}
      }
    },
    "technical_references": {
      "type": "object",
      "description": "Centralized technical documentation, research papers, frameworks, and design patterns",
      "properties": {
        "_description": {"type": "string"},
        "_usage": {"type": "string"},
        "_last_updated": {"type": "string"},
        "anthropic_claude": {"type": "object"},
        "model_context_protocol": {"type": "object"},
        "aws_bedrock": {"type": "object"},
        "aws_bedrock_agentcore": {"type": "object"},
        "aws_bedrock_strands": {"type": "object"},
        "aws_general": {"type": "object"},
        "langchain": {"type": "object"},
        "streamlit": {"type": "object"},
        "github": {"type": "object"},
        "cursor_ide": {"type": "object"},
        "data_tools": {"type": "object"},
        "testing": {"type": "object"},
        "research_papers": {"type": "object"},
        "design_patterns": {"type": "object"},
        "validation_framework": {"type": "object"}
      }
    },
    "self_improvement_framework": {
      "type": "object",
      "description": "Shared framework for all agent self-improvement prompts",
      "properties": {
        "_description": {"type": "string"},
        "_usage": {"type": "string"},
        "_last_updated": {"type": "string"},
        "purpose": {"type": "string"},
        "applicable_agents": {"type": "object"},
        "recursion_prevention": {"type": "object"},
        "core_principles": {"type": "object"},
        "standard_methodology": {"type": "object"},
        "quality_benchmarks": {"type": "object"},
        "success_criteria": {"type": "object"},
        "validation_requirements": {"type": "object"},
        "common_focus_areas": {"type": "object"}
      }
    },
    "validation_framework": {
      "type": "object",
      "description": "Shared validation and self-improvement patterns for all engineering agents",
      "properties": {
        "_description": {"type": "string"},
        "_applies_to": {"type": "string"},
        "_last_updated": {"type": "string"},
        "overview": {"type": "object"},
        "validation_workflow": {"type": "object"},
        "quality_benchmarks": {"type": "object"},
        "trm_pattern": {"type": "object"},
        "anthropic_patterns": {"type": "object"},
        "aws_bedrock_integration": {"type": "object"},
        "implementation_requirements": {"type": "object"},
        "integration_points": {"type": "object"}
      }
    },
    "_usage_notes": {
      "type": "object"
    }
  }
}
