{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "estimate.schema.json",
  "title": "Estimate",
  "description": "Cost models, LOE breakdowns, team composition, and confidence scoring produced by /estimate skill.",
  "type": "object",
  "required": ["engagement_id", "version", "status", "team_composition", "loe_breakdown", "cost_model"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "description": "JSON Schema reference" },
    "$depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Upstream KB file dependencies"
    },
    "engagement_id": {
      "type": "string",
      "pattern": "^eng-\\d{4}-\\d{3,}$",
      "description": "Links to engagement.json"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "MAJOR.MINOR — major on structure change, minor on content"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in_progress", "complete", "approved"],
      "description": "Lifecycle status"
    },

    "methodology": {
      "type": "string",
      "enum": ["bottom_up", "top_down", "three_point", "analogous", "parametric"],
      "description": "Primary estimation methodology. SKILL.md refers to this as estimation_method."
    },

    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Overall confidence level. SKILL.md refers to this as confidence_summary."
    },

    "currency": { "type": "string", "default": "USD", "description": "Currency for all monetary values" },

    "complexity_assessment": {
      "type": "object",
      "description": "10-point complexity checklist with score and buffer (SKILL.md field)"
    },

    "complexity_rating": {
      "type": "string",
      "enum": ["low", "medium", "high", "very_high"],
      "description": "Overall complexity rating"
    },

    "complexity_factors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key complexity drivers"
    },

    "team_composition": {
      "type": "array",
      "minItems": 1,
      "description": "Roles, seniority, allocation, hiring timeline",
      "items": {
        "type": "object",
        "required": ["role", "count", "duration_weeks"],
        "properties": {
          "role": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 },
          "experience_level": { "type": "string", "enum": ["junior", "mid_level", "senior", "expert"] },
          "allocation_percent": { "type": "number", "minimum": 0, "maximum": 100 },
          "duration_weeks": { "type": "integer", "minimum": 1 },
          "hourly_rate": { "type": "number", "minimum": 0 },
          "total_cost": { "type": "number", "minimum": 0 },
          "responsibilities": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "loe_breakdown": {
      "type": "object",
      "required": ["total_hours", "by_phase"],
      "description": "Per-phase effort with hours, points, and confidence",
      "properties": {
        "total_hours": { "type": "number", "minimum": 0 },
        "by_phase": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase", "hours", "weeks"],
            "properties": {
              "phase": { "type": "string" },
              "hours": { "type": "number", "minimum": 0 },
              "weeks": { "type": "number", "minimum": 0 },
              "parallel": { "type": "boolean" }
            }
          }
        },
        "by_component": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["component", "hours"],
            "properties": {
              "component": { "type": "string" },
              "hours": { "type": "number", "minimum": 0 },
              "complexity": { "type": "string", "enum": ["low", "medium", "high", "very_high"] }
            }
          }
        },
        "risk_buffer": {
          "type": "object",
          "properties": {
            "percent": { "type": "number", "minimum": 0, "maximum": 100 },
            "hours": { "type": "number", "minimum": 0 },
            "rationale": { "type": "string" }
          }
        }
      }
    },

    "cost_model": {
      "type": "object",
      "required": ["development", "infrastructure_monthly", "total_first_year"],
      "description": "5-category cost breakdown with assumptions",
      "properties": {
        "development": {
          "type": "object",
          "properties": {
            "internal_team": { "type": "number" },
            "contractors": { "type": "number" },
            "training": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "infrastructure_monthly": {
          "type": "object",
          "description": "Monthly recurring infrastructure costs. Keys are service names, values are USD amounts.",
          "properties": {
            "total": { "type": "number" }
          },
          "additionalProperties": { "type": "number" }
        },
        "infrastructure_first_year": { "type": "number" },
        "third_party_monthly": {
          "type": "object",
          "properties": {
            "total": { "type": "number" }
          },
          "additionalProperties": { "type": "number" }
        },
        "total_first_year": { "type": "number" },
        "tco_3_year": {
          "type": "object",
          "description": "3-year total cost of ownership",
          "properties": {
            "year_1": { "type": "number" },
            "year_2": { "type": "number" },
            "year_3": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "roi": {
          "type": "object",
          "description": "Return on investment projections",
          "properties": {
            "annual_savings_estimate": { "type": "number" },
            "payback_period_months": { "type": "number" },
            "roi_3_year_percent": { "type": "number" }
          }
        }
      }
    },

    "three_pass_context": {
      "type": "object",
      "description": "Which pass, accuracy target, caveats (SKILL.md field)"
    },

    "optimization_strategies": {
      "type": "array",
      "description": "Cost reduction opportunities (SKILL.md field)",
      "items": { "type": "object" }
    },

    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Cost and timeline assumptions"
    },

    "_metadata": {
      "type": "object",
      "description": "Estimate-specific metadata",
      "properties": {
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "validation_status": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "estimator": { "type": "string" },
        "estimation_date": { "type": "string", "format": "date" }
      }
    }
  }
}
