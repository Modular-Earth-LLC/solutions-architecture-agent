{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engagement.schema.json",
  "title": "Engagement Envelope",
  "description": "Top-level engagement metadata, lifecycle tracking, and cross-references between skill outputs. Written by any skill that starts an engagement.",
  "type": "object",
  "required": [
    "engagement_id",
    "title",
    "engagement_type",
    "status",
    "created_date",
    "lifecycle_state"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "$depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Upstream KB file dependencies"
    },
    "engagement_id": {
      "type": "string",
      "pattern": "^eng-\\d{4}-\\d{3,}$",
      "description": "Unique engagement identifier: eng-YYYY-NNN"
    },
    "title": {
      "type": "string",
      "maxLength": 200,
      "description": "Human-readable engagement title"
    },
    "engagement_type": {
      "type": "string",
      "enum": [
        "greenfield",
        "migration",
        "modernization",
        "augmentation",
        "assessment"
      ],
      "description": "greenfield = 0-to-1 new build. migration = move from legacy. modernization = upgrade existing. augmentation = add AI to existing. assessment = review only."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_progress",
        "in_review",
        "approved",
        "on_hold",
        "completed",
        "cancelled"
      ],
      "description": "Overall engagement status (broader than domain file status)"
    },
    "created_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date when engagement was created"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date of last update"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "MAJOR.MINOR — major on structure change, minor on content"
    },
    "client": {
      "type": "object",
      "required": [
        "name"
      ],
      "description": "Client information for this engagement",
      "properties": {
        "name": {
          "type": "string",
          "description": "Client company name"
        },
        "industry": {
          "type": "string",
          "description": "Client industry vertical"
        },
        "contact": {
          "type": "string",
          "description": "Primary client contact"
        },
        "size": {
          "type": "string",
          "enum": [
            "startup",
            "smb",
            "mid_market",
            "enterprise"
          ],
          "description": "Client company size category"
        }
      }
    },
    "lifecycle_state": {
      "type": "object",
      "description": "Status of each skill domain. Skills update their own entry.",
      "required": [
        "requirements",
        "architecture"
      ],
      "properties": {
        "requirements": {
          "$ref": "#/$defs/lifecycle_entry"
        },
        "architecture": {
          "$ref": "#/$defs/lifecycle_entry"
        },
        "data_model": {
          "$ref": "#/$defs/lifecycle_entry"
        },
        "security_review": {
          "$ref": "#/$defs/lifecycle_entry"
        },
        "integration_plan": {
          "$ref": "#/$defs/lifecycle_entry"
        },
        "estimate": {
          "$ref": "#/$defs/lifecycle_entry"
        },
        "project_plan": {
          "$ref": "#/$defs/lifecycle_entry"
        }
      },
      "additionalProperties": false
    },
    "review_summary": {
      "type": "object",
      "description": "Aggregated review status from /review skill",
      "properties": {
        "total_reviews": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of reviews conducted"
        },
        "latest_overall_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 10,
          "description": "Most recent review score (null if no reviews)"
        },
        "blocking_findings": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of unresolved blocking findings"
        }
      }
    },
    "engagement_depth": {
      "type": "string",
      "enum": [
        "QUICK",
        "STANDARD",
        "COMPREHENSIVE"
      ],
      "description": "Default depth tier for this engagement. Individual skills may override."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Free-form tags for engagement categorization"
    },
    "_migration": {
      "type": "object",
      "description": "Legacy migration tracking (temporary, remove after full migration)",
      "properties": {
        "legacy_requirements_file": {
          "type": "string"
        },
        "legacy_decisions_file": {
          "type": "string"
        },
        "migration_complete": {
          "type": "boolean"
        }
      }
    },
    "_metadata": {
      "type": "object",
      "description": "Skill-specific metadata (author, date, validation_status, version, plus skill-specific fields)",
      "properties": {
        "author": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "validation_status": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$"
        }
      }
    }
  },
  "$defs": {
    "lifecycle_entry": {
      "type": "object",
      "required": [
        "status",
        "version",
        "file"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "in_progress",
            "draft",
            "complete",
            "approved"
          ],
          "description": "Domain status (5-value enum including not_started)"
        },
        "version": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d+\\.\\d+$",
          "description": "Current version of the domain file (null when not_started)"
        },
        "file": {
          "type": "string",
          "description": "Filename of the domain KB file"
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        },
        "reviewed": {
          "type": "boolean",
          "default": false
        },
        "depth": {
          "type": "string",
          "enum": [
            "QUICK",
            "STANDARD",
            "COMPREHENSIVE"
          ],
          "description": "Depth tier used when this skill was executed"
        }
      }
    }
  }
}
