{
  "$schema": "./schemas/data_model.schema.json",
  "$depends_on": ["engagement.json", "requirements.json", "architecture.json"],
  "engagement_id": "eng-2026-001",
  "version": "1.1",
  "last_updated": "2026-03-16",
  "status": "complete",

  "data_requirements": {
    "sources": [
      { "name": "IBMi Db2 for i", "type": "relational", "format": "EBCDIC fixed-length, packed decimal", "volume": "Petabytes accumulated", "access_pattern": "Write-heavy (claims adjudication), read-heavy (eligibility lookups)", "quality": "Production-grade for claims; needs EBCDIC→UTF-8, date format, packed decimal transformation for cloud" },
      { "name": "NCPDP Claims Stream", "type": "streaming", "format": "NCPDP Telecommunication Standard v.D.0 (B1)", "volume": "Millions of real-time claims/day at POS", "access_pattern": "Real-time write, sub-second latency", "quality": "Standardized format; validated by pharmacy systems" },
      { "name": "Clinical Notes / PA Docs", "type": "unstructured", "format": "Free text, scanned PDFs", "volume": "Variable, growing with GenAI pipeline", "access_pattern": "Write-once, read-many for NLP processing", "quality": "Unstructured; requires NLP/LLM extraction for structured output" },
      { "name": "myPBM (Azure)", "type": "api", "format": "REST JSON", "volume": "Client management traffic", "access_pattern": "Read-write via 130+ APIs", "quality": "Modern API architecture; well-structured" },
      { "name": "CDC Journal Stream", "type": "streaming", "format": "Journal entries (PT/UP/DL)", "volume": "Continuous all DB changes", "access_pattern": "Append-only event stream", "quality": "High — direct from IBM i journals" }
    ],
    "retention": {
      "hipaa_minimum_years": 6,
      "hipaa_retention_days": 2190,
      "audit_logs": "6 years minimum (HIPAA §164.530(j))",
      "claims_data": "7 years (HIPAA + state pharmacy board requirements)",
      "clinical_notes": "6 years from last service date",
      "ai_evaluation_logs": "3 years (model governance + audit trail)"
    },
    "data_residency": "United States only (us-east1 primary, us-central1 DR)",
    "encryption": "AES-256 at rest (CMEK via Cloud KMS), TLS 1.2+ in transit",
    "non_relational_stores": [
      { "name": "Cloud Healthcare API FHIR Store", "type": "document", "purpose": "HL7 FHIR R4 resources (Patient, MedicationRequest, Condition, Coverage). Schema governed by FHIR standard — no custom schema design needed. Used for interoperability with external healthcare systems.", "access_pattern": "FHIR REST API with SMART on FHIR scopes" },
      { "name": "Memorystore Redis", "type": "cache", "purpose": "Ephemeral cache for member eligibility, formulary lookups, and session state. TTL-managed, no persistent data. Reduces IBMi API call volume by 60-80% for hot-path lookups.", "access_pattern": "Key-value get/set with TTL expiration" },
      { "name": "Pub/Sub + BigQuery Event Store", "type": "event_store", "purpose": "Append-only event stream for CDC events, claims status changes, PA lifecycle events, and Health100 notifications. Pub/Sub for real-time routing, BigQuery for durable event storage and analytics.", "access_pattern": "Pub/Sub publish/subscribe for real-time; BigQuery SQL for historical analytics" }
    ]
  },

