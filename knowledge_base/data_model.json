  "ontology": {
    "domain": "Pharmacy Benefits Management (PBM)",
    "key_concepts": [
      { "concept": "Claims Adjudication", "definition": "Real-time processing of pharmacy claims at point of service via NCPDP B1 transactions — eligibility check, DUR screening, UM review, pricing calculation, approval/denial", "related_to": ["DUR", "Formulary", "Prior Authorization", "Member Eligibility"] },
      { "concept": "Drug Utilization Review (DUR)", "definition": "Automated screening for drug interactions, therapeutic duplications, contraindications, and inappropriate dosing during claims adjudication", "related_to": ["Claims Adjudication", "Drug Products", "Clinical Decision Support"] },
      { "concept": "Formulary", "definition": "Approved drug list with tier assignments (generic, preferred brand, non-preferred, specialty) determining copay structure and coverage rules", "related_to": ["Plans", "Drug Products", "Prior Authorization", "Step Therapy"] },
      { "concept": "Prior Authorization", "definition": "Clinical review process requiring provider justification before plan covers specific medications — increasingly AI-assisted for standard cases", "related_to": ["GenAI Pipeline", "Clinical Notes", "Formulary", "Clinical Pharmacist"] },
      { "concept": "NDC (National Drug Code)", "definition": "11-digit unique identifier for drug products in the US market: labeler (5 digits) + product (4 digits) + package (2 digits)", "related_to": ["Drug Products", "Claims", "Formulary"] },
      { "concept": "NPI (National Provider Identifier)", "definition": "10-digit unique identifier for healthcare providers and pharmacies required for all HIPAA-covered transactions", "related_to": ["Pharmacies", "Providers", "Claims"] },
      { "concept": "NCPDP", "definition": "National Council for Prescription Drug Programs — standards body for pharmacy claims transactions (B1 transaction format)", "related_to": ["Claims Adjudication", "Pharmacies"] },
      { "concept": "Strangler Fig Migration", "definition": "Incremental modernization pattern: extract legacy functionality into APIs, route traffic to modern implementation, validate equivalence via Dual Run, decommission legacy screen", "related_to": ["Migration Status", "Dual Run", "Feature Toggles"] }
    ]
  },

  "validation_rules": {
    "member_validation": [
      "member_id: NOT NULL, unique, max 20 characters",
      "date_of_birth: valid date, must be in the past, must be after 1900-01-01",
      "eligibility_status: must be one of ACTIVE, INACTIVE, TERMED",
      "plan_id: must reference existing plan in plans table",
      "ssn_hash: if present, must be exactly 64 chars (SHA-256)"
    ],
    "claims_validation": [
      "drug_ndc: must be valid 11-digit NDC format (regex: ^\\d{11}$)",
      "pharmacy_npi: must be valid 10-digit NPI (regex: ^\\d{10}$)",
      "quantity_dispensed: must be > 0",
      "days_supply: must be between 1 and 365",
      "date_of_service: must not be in the future",
      "cost fields (ingredient_cost, dispensing_fee, copay_amount, plan_pay_amount, patient_pay_amount): must be >= 0",
      "plan_pay_amount + patient_pay_amount must approximately equal ingredient_cost + dispensing_fee (tolerance: $0.01)"
    ],
    "pa_validation": [
      "clinical_notes_text: max 10,000 characters",
      "urgency: must be one of ROUTINE, URGENT, EMERGENCY",
      "status transitions must follow: SUBMITTED → IN_REVIEW → AI_RECOMMENDATION_PENDING → PHARMACIST_REVIEW → APPROVED/DENIED/APPEALED",
      "reviewer_decision requires reviewer_user_id and decision_timestamp",
      "AI recommendation requires confidence score between 0.0 and 1.0"
    ],
    "cross_entity_validation": [
      "Claims: member must have eligibility_status = ACTIVE on date_of_service",
      "Claims: drug_ndc must exist in formulary for member's plan on date_of_service",
      "PA: member must have active plan enrollment",
      "Formulary entries: effective_date must be <= today for active entries",
      "Users: mfa_enabled must be true for roles accessing PHI"
    ]
  },

  "data_governance": {
    "data_classification": {
      "basis": "HIPAA §164.312 Technical Safeguards, NIST 800-122",
      "tiers": {
        "RESTRICTED": {
          "description": "PHI and highly sensitive clinical data requiring maximum protection",
          "entities": ["members (PHI fields: name, DOB, SSN hash, address, phone, email)", "prior_authorizations (clinical_notes_text, diagnosis_codes, supporting_documents)", "ai_recommendations (extracted_entities may contain PHI — de-identified before model inference)"],
          "controls": "CMEK encryption, Cloud DLP scanning, VPC-SC perimeter, audit logging on all access, RLS enforcement, SMART on FHIR scopes, BigQuery column-level security"
        },
        "CONFIDENTIAL": {
          "description": "Business-sensitive data requiring standard protection",
          "entities": ["plans (benefit structures, copay rates)", "formularies (drug coverage decisions)", "formulary_entries (tier assignments, PA requirements)", "providers (NPI, DEA numbers)", "drug_products (formulary-relevant attributes)", "users (credentials, role assignments, IBMi profile mapping)"],
          "controls": "CMEK encryption, RBAC access control, audit logging for write operations, network segmentation"
        },
        "INTERNAL": {
          "description": "Operational data with standard internal controls",
          "entities": ["migration_status (migration tracking, adoption metrics)", "cdc_sync_log (synchronization monitoring)", "pharmacies (public network information)"],
          "controls": "Encryption at rest, standard RBAC, operational monitoring"
        }
      }
    },
    "pii_fields": [
      "members.first_name (PHI)", "members.last_name (PHI)", "members.date_of_birth (PHI)",
      "members.ssn_hash (PHI — hashed, never plaintext)", "members.address_* (PHI)",
      "members.phone (PHI)", "members.email (PHI)",
      "providers.first_name (PII)", "providers.last_name (PII)", "providers.dea_number (sensitive)",
      "prior_authorizations.clinical_notes_text (PHI)", "prior_authorizations.diagnosis_codes (PHI)",
      "prior_authorizations.supporting_documents (PHI)",
      "ai_recommendations.extracted_entities (may contain PHI — de-identified before model inference)",
      "claims.member_id (indirect PHI identifier)", "claims.prescriber_npi (PII)",
      "audit_log.source_ip (PII)", "audit_log.user_agent (PII)",
      "users.email (PII)", "users.identity_provider_id (PII)"
    ],
    "retention_policy": "HIPAA minimum 6 years (2190 days) for all PHI-containing records and audit logs. Claims data retained 7 years per state pharmacy board requirements. AI evaluation logs retained 3 years for model governance. Application logs retained 90 days in Cloud Logging, archived to Cloud Storage Coldline. CDC sync logs retained 90 days.",
    "encryption": "AES-256 at rest via Cloud KMS Customer-Managed Encryption Keys (CMEK). Separate key rings per data classification: one for PHI data stores, one for operational data, one for AI model artifacts. TLS 1.2+ for all data in transit. IPsec encryption over Partner Interconnect for IBMi connectivity (<5ms overhead). SSN never stored in plaintext — SHA-256 hash only in cloud; original SSN remains only on IBMi.",
    "access_control": "Hybrid RBAC + ABAC model. Base roles: CLAIMS_PROCESSOR (read claims/members, process adjudication), CLINICAL_PHARMACIST (read/write PA, view AI recommendations, formulary management), BENEFITS_ANALYST (read analytics, run reports), IT_ADMINISTRATOR (user management, system config, migration dashboard). ABAC attributes: DEA certification (required for controlled substance data), department, location, time of access. Cloud SQL row-level security policies enforce tenant isolation. BigQuery column-level security masks PHI in analytics queries for non-clinical roles. SMART on FHIR scopes control clinical data access at API level."
  },

  "migration_notes": {
    "schema_evolution_strategy": "Additive-only migrations during transition period. New columns added as nullable with defaults. No column renames or type changes while CDC is active — these require coordinated migration windows. Schema versioning tracked in migration_status table. Flyway or Liquibase for Cloud SQL schema migrations. BigQuery schema evolution is automatic for additive changes.",
    "ibmi_to_cloud_data_mapping": "Critical transformations during CDC: EBCDIC → UTF-8 encoding, IBM packed decimal → PostgreSQL NUMERIC, IBM date formats (YYYYMMDD packed, CYYMMDD) → ISO 8601, single-character status codes (A/I/T) → descriptive enums (ACTIVE/INACTIVE/TERMED), library/file naming → schema.table naming. Transformation logic implemented in Dataflow (Apache Beam) between Pub/Sub and Cloud SQL/BigQuery.",
    "initial_load_strategy": "Historical data backfill via batch ETL during maintenance window (Sundays 02:00-06:00 ET). Priority order: (1) member reference data, (2) drug/pharmacy/provider reference data, (3) formulary data, (4) active claims (rolling 12 months), (5) historical claims (remaining 7 years to BigQuery only). CDC activated before initial load to capture changes during backfill — deduplication via journal entry timestamp.",
    "dual_write_period": "During migration phases, writes continue through IBMi (system of record). Cloud SQL receives updates via CDC with eventual consistency (target lag ≤ 5 seconds). No dual-write from cloud to IBMi — unidirectional until a workflow is fully cutover. After cutover, Cloud SQL becomes system of record for that domain; IBMi receives reverse CDC for remaining legacy consumers."
  },

