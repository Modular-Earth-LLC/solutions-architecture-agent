{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(claude *)",
      "WebFetch",
      "WebSearch",
      "mcp__microsoft-learn__*",
      "mcp__cms-coverage-db__*",
      "mcp__npi-registry__*",
      "mcp__icd10-codes__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ]
  },
  "enabledMcpjsonServers": [
    "microsoft-learn",
    "cms-coverage-db",
    "npi-registry",
    "icd10-codes"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/protect-sensitive-files.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-remote-ready.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "solutions-architecture-agent": {
      "source": {
        "source": "directory",
        "path": "."
      }
    }
  },
  "enabledPlugins": {
    "solutions-architecture-agent@solutions-architecture-agent": true
  }
}
